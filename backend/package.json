  "version": "1.0.0",
  "description": "Production-grade backend for LinkForge AI URL Shortener",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
